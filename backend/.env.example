# App Configuration
DEBUG=False
APP_NAME=Algo Trading Platform

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/algo_trading

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Zerodha API
ZERODHA_API_KEY=your-zerodha-api-key
ZERODHA_API_SECRET=your-zerodha-api-secret
ZERODHA_REDIRECT_URL=http://localhost:8000/api/broker/zerodha/callback

# Encryption
ENCRYPTION_KEY=change-me-in-production-32-char-key
